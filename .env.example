# Copy these into Vercel → Project → Settings → Environment Variables
# (Production + Preview + Development)

# Required — your Resend secret key (re_xxx…)
RESEND_API_KEY=

# Required for storing contacts — create in Resend → Audiences, copy the UUID
RESEND_AUDIENCE_ID=

# Where to send "new signup" notifications (defaults to hello@nomad-lab.io)
NOTIFY_EMAIL=hello@nomad-lab.io

# Sender line. Must use a domain verified in Resend.
# Until your domain is verified, you can use: onboarding@resend.dev
NOTIFY_FROM=PostKit Waitlist <waitlist@nomad-lab.io>
